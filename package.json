{
  "name": "men-eat-pb",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --open /admin.html",
    "dev:api": "wrangler dev --config wrangler.jsonc",
    "start": "vite --open",
    "build": "node scripts/write-build-stamp.mjs && vite build",
    "build:admin": "vite build --config vite.admin.config.ts",
    "check:api": "tsc -p feedback-api/tsconfig.json --noEmit && wrangler deploy --dry-run --config wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply men-eat-pb-feedback --local",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "tsc --noEmit && npm run check:api && vitest run && vite build && vite build --config vite.admin.config.ts",
    "package:itch": "powershell -ExecutionPolicy Bypass -File ./scripts/package-itchio.ps1",
    "qa:browser": "powershell -ExecutionPolicy Bypass -File ./scripts/browser-qa.ps1 -Action tutorial-smoke"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "wrangler": "^4.100.0"
  }
}
