## Optional: direct API endpoint for the in-game feedback form.
## Expected contract: POST JSON feedback payload, returns { "id": "...", "reviewUrl": "..." }.
VITE_PLAYTEST_FEEDBACK_API_URL=

## Optional: fallback URL for the in-game "Open issue instead" button.
## GitHub example:
## VITE_PLAYTEST_FEEDBACK_URL=https://github.com/OWNER/men-eat-pb/issues/new?template=playtest-feedback.md
## GitLab example:
## VITE_PLAYTEST_FEEDBACK_URL=https://gitlab.com/GROUP/men-eat-pb/-/issues/new
VITE_PLAYTEST_FEEDBACK_URL=

## Optional: volunteer admin API. Defaults to VITE_PLAYTEST_FEEDBACK_API_URL when unset.
## Expected contract: GET /feedback?status=pending and PATCH /feedback/:id.
VITE_PLAYTEST_ADMIN_API_URL=
